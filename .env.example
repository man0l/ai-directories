# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then load before running any script:
#   set -a && source .env && set +a

# --- Required ---
SUBMIT_PRODUCT_URL=https://yourproduct.com
SUBMIT_PRODUCT_NAME=Your Product Name
SUBMIT_TAGLINE=Your one-line tagline
SUBMIT_EMAIL=you@throwaway.com
SUBMIT_AUTHOR_NAME=Jane Doe

# --- Recommended ---
SUBMIT_AUTHOR_FIRST=Jane
SUBMIT_AUTHOR_LAST=Doe
SUBMIT_USERNAME=youruser
SUBMIT_PASSWORD=throwaway-password

# --- Optional ---
SUBMIT_GITHUB_URL=https://github.com/you/repo
SUBMIT_TWITTER_URL=https://twitter.com/yourhandle
SUBMIT_KEYWORDS=ai,saas,marketing,automation
SUBMIT_LOGO=logo.png
SUBMIT_SCREENSHOT=site-image.png
